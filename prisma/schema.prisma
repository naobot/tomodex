generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  // --- for NextAuth ---
  emailVerified DateTime?
  image         String?
  // --------------------------
  createdAt     DateTime  @default(now())

  // --- for NextAuth ---
  accounts Account[]
  // --------------------------

  people           Person[]
  notes            Note[]
  customAttributes CustomAttribute[]
  phoneNumbers     PhoneNumber[]
  emailAddresses   EmailAddress[]
  mailingAddresses MailingAddress[]
  locations        Location[]
}

// --- for NextAuth ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
}
// --------------------------

model Person {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  displayName String
  fullName    String?
  birthDay    Int?
  birthMonth  Int?
  birthYear   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  phoneNumbers     PhoneNumber[]
  emailAddresses   EmailAddress[]
  mailingAddresses MailingAddress[]
  location         Location?
  notes            Note[]
  customAttributes CustomAttribute[]

  @@index([ownerId])
  @@index([displayName])
  @@index([birthMonth])
}

// Renamed from Address — freeform postal/mailing address for letters and packages
model MailingAddress {
  id             String  @id @default(cuid())
  ownerId        String
  owner          User    @relation(fields: [ownerId], references: [id])
  personId       String
  person         Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  label          String?
  mailingAddress String
}

// One per person — where they currently live
model Location {
  id       String  @id @default(cuid())
  ownerId  String
  owner    User    @relation(fields: [ownerId], references: [id])
  personId String  @unique  // @unique enforces the one-to-one at the database level
  person   Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  city     String?
  country  String?
}

model PhoneNumber {
  id        String  @id @default(cuid())
  ownerId   String
  owner     User    @relation(fields: [ownerId], references: [id])
  personId  String
  person    Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  label     String?
  number    String
}

model EmailAddress {
  id        String  @id @default(cuid())
  ownerId   String
  owner     User    @relation(fields: [ownerId], references: [id])
  personId  String
  person    Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  label     String?
  address   String
}

model Note {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomAttribute {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  key       String
  value     String
  createdAt DateTime @default(now())
}